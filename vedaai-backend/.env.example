# Local MongoDB
# MONGO_URL=mongodb://127.0.0.1:27017/vedaai

# MongoDB Atlas (Database → Connect → Drivers). Replace user, password, cluster host, and db name.
# MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/vedaai?retryWrites=true&w=majority

# Standard connection string (no SRV — avoids DNS querySrv issues). Copy from Atlas; include replicaSet, ssl, authSource.
# MONGO_URL=mongodb://<user>:<password>@shard-00-00.<cluster>.mongodb.net:27017,.../dbname?ssl=true&replicaSet=...&authSource=admin&retryWrites=true&w=majority

MONGO_URL=

# If querySrv ECONNREFUSED on mongodb+srv: set to 0 only if you must use corporate DNS only.
# MONGO_USE_PUBLIC_DNS=0
# Or set custom resolvers: MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

REDIS_URL=
GROQ_API_KEY=

PORT=5000

# Comma-separated browser origins allowed to call this API (required in production if frontend is on another domain).
# Example: https://your-app.vercel.app,http://localhost:3000
# Leave unset during local dev to allow all origins (same as before).
ALLOWED_ORIGINS=
