{
  "name": "vedaai-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:worker\" \"npm run dev:pdf\"",
    "dev:server": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/workers/generation.worker.ts",
    "dev:pdf": "ts-node-dev --respawn --transpile-only src/workers/pdf.worker.ts",
    "build": "tsc",
    "start": "concurrently \"node dist/server.js\" \"node dist/workers/generation.worker.js\" \"node dist/workers/pdf.worker.js\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.14.0",
    "bullmq": "^5.71.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "mongoose": "^9.3.1",
    "msedge-tts": "^2.0.4",
    "multer": "^2.1.1",
    "openai": "^6.32.0",
    "pdf2pic": "^3.2.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
